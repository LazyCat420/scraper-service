# ============================================================
# scraper-service — Environment Variables
# ============================================================

# Server
HOST=0.0.0.0
PORT=8001

# Default HTTP client
DEFAULT_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# Reddit (asyncpraw)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=scraper-service/1.0

# YouTube (optional cookies for transcript access)
YOUTUBE_COOKIES_FILE=

# Vision engine (optional)
PRISM_URL=http://prism-service:7777/agent

# Proxy rotation (comma-separated list)
PROXY_LIST=

# Twitter/X (twscrape — burner accounts only, NEVER your real account)
# JSON array: [{"username":"x","password":"x","email":"x@y.com","email_password":"x"}]
TWITTER_ACCOUNTS=[]
