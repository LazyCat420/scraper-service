# ============================================================
# scraper-service — Environment Variables
# ============================================================

# Server
HOST=0.0.0.0
PORT=8001

# Default HTTP client
DEFAULT_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# Reddit (asyncpraw)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=scraper-service/1.0

# YouTube (optional cookies for transcript access)
YOUTUBE_COOKIES_FILE=

# Vision engine (optional)
OPENAI_API_KEY=
OLLAMA_URL=http://localhost:11434

# Proxy rotation (comma-separated list)
PROXY_LIST=
